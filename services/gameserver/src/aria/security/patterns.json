{
  "version": 1,
  "description": "WO-ARIA-PROMPT-DEFENSE: versioned prompt-injection pattern list (ADR-0057 A-V1 layer 4 -- defense-in-depth, NOT the primary defense; layers 3+5 are load-bearing). Consolidates the previously-inline regex lists that lived in enhanced_ai_service.py's _filter_prompt_injections (now removed per Accept #4) and the overlapping subset already present in ai_security_service.py's detect_ai_attacks/detect_ai_specific_attacks (those two stay as-is -- out of this WO's scope; see the census note in the shipping report). 'action' is schema-forward: every entry currently ships as 'filter' (replace the match with '[filtered]', non-blocking -- preserves the exact behavior _filter_prompt_injections already had) so this migration is a pure refactor, not a behavior change. A future WO can promote specific entries to 'block' without a schema change.",
  "patterns": [
    {"pattern": "ignore\\s+(previous|all|above|system|your)\\s+(instructions|prompts?|commands?|training)", "class": "instruction_override", "action": "filter"},
    {"pattern": "disregard\\s+(previous|above|all)", "class": "instruction_override", "action": "filter"},
    {"pattern": "forget\\s+(everything|all|that|your\\s+role)", "class": "instruction_override", "action": "filter"},
    {"pattern": "override\\s+(instructions|your\\s+programming|your|system|safety|security)", "class": "instruction_override", "action": "filter"},
    {"pattern": "new\\s+(instructions?|task|role)\\s*:?", "class": "instruction_override", "action": "filter"},
    {"pattern": "you\\s+are\\s+now", "class": "role_confusion", "action": "filter"},
    {"pattern": "act\\s+as\\s+a", "class": "role_confusion", "action": "filter"},
    {"pattern": "act\\s+as\\s+if", "class": "role_confusion", "action": "filter"},
    {"pattern": "act\\s+as\\s+(if\\s+)?you\\s+are", "class": "role_confusion", "action": "filter"},
    {"pattern": "pretend\\s+(you\\s+are|to\\s+be)", "class": "role_confusion", "action": "filter"},
    {"pattern": "imagine\\s+you\\s+are", "class": "role_confusion", "action": "filter"},
    {"pattern": "roleplay\\s+as", "class": "role_confusion", "action": "filter"},
    {"pattern": "system\\s*[:\\-]\\s*you", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "assistant\\s*[:\\-]\\s*you", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "human\\s*[:\\-]\\s*you", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "###\\s*(system|assistant|user)", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "\\\\n\\\\nhuman:", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "\\\\n\\\\nassistant:", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "<\\|im_start\\|>", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "<\\|im_end\\|>", "class": "delimiter_injection", "action": "filter"},
    {"pattern": "jailbreak", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "dan\\s+mode", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "developer\\s+mode", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "admin\\s+mode", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "sudo\\s+mode", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "god\\s+mode", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "unrestricted\\s+mode", "class": "jailbreak_mode", "action": "filter"},
    {"pattern": "exec\\s*\\(", "class": "code_execution", "action": "filter"},
    {"pattern": "eval\\s*\\(", "class": "code_execution", "action": "filter"},
    {"pattern": "__import__", "class": "code_execution", "action": "filter"},
    {"pattern": "import\\s+(os|subprocess)", "class": "code_execution", "action": "filter"},
    {"pattern": "```python", "class": "code_execution", "action": "filter"}
  ]
}
